{
  "use_ipv4" : true,
  "base_url" : "https://#ICE_SERVER_HOST#",
  "https_port" : 443,
  "allow_registration" : true,
  "verbose" : true,
  "logfile" : null,
  "interface" : "0.0.0.0",
  "mail_domain" : "#MAIL_DOMAIN#",
  "imap_host" : "127.0.0.1",
  "imap_restapi_port" : 8000,
  "imap_port" : 993,
  "imap_ssl" : true,
  "messages_batch_size" : 100,
  "ssl": {
    "cert": "#SSL_CERT_PATH#",
    "key": "#SSL_KEY_PATH#"
  },
  "web_content" : "./WebContent",
  "database" : {
    "type" : "sqlite3",
    "configuration" :  {
      "db_file" : "./ICEMail.sqlite"}
  },
  "admin" : { "password" :  "#ADMIN_PASSWORD#",
              "allowed_hosts" : ["127.0.0.1","#ADMIN_CLIENT#"] },
  "internal_mailer" : {
    "internal_mail_user" : "mailer",
    "internal_mail_user_password" : "whatever",
    "smtp_host" : "localhost",
    "smtp_port" : 587,
    "starttls" : true
  },
  "dovecot_sasl" : {
    "enabled" : true,
    "port" : 12345,
    "bind_address" : "127.0.0.1"
  },
  "altcha" : {
    "hmac_key" : "#ALTCHA_RANDOM#"
  },
  "postfix_after_queue" : {
    "port" : 10026,
    "requeue_port" : 10027,
    "enabled" : true,
    "decrypt_message_ttl_hours" : 72
  },
    "postfix_policy_server" : {
	"enabled" :true,
	"port": 10028
    }
}
